# Supabase DB connection (find in Supabase dashboard → Settings → Database)
SUPABASE_DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-supabase-db-password

# Neon DB connection (find in Neon dashboard → Connection string)
NEON_DB_HOST=ep-xxxxxxxx.eu-central-1.aws.neon.tech
NEON_DB_PORT=5432
NEON_DB_NAME=neondb
NEON_DB_USER=neondb_owner
NEON_DB_PASSWORD=your-neon-db-password
